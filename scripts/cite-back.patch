+        <entry key='Recording, musical' value='song'/>
+        <entry key='Recording, oral' value='speech'/>
+        <entry key='Software' value='software'/>
+        <entry key='Technical Report' value='report'/>
+        <entry key='Thesis' value='thesis'/>
